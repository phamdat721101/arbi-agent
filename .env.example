# Arbitrum RPC
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Agent wallet — single wallet for both seller and buyer
AGENT_PRIVATE_KEY=0x...your_private_key...
AGENT_WALLET_ADDRESS=0x...your_address...

# Buyer wallet (defaults to AGENT_PRIVATE_KEY if not set)
BUYER_PRIVATE_KEY=

# OpenAI
OPENAI_API_KEY=sk-...

# x402 Local Facilitator
X402_FACILITATOR_URL=http://localhost:3002
FACILITATOR_PORT=3002
ENABLE_SETTLEMENT=false
MERCHANT_API_KEY=dev-api-key

# Mock USDC (set after running: npm run deploy:usdc)
MOCK_USDC_ADDRESS=

# Network (use arbitrum-sepolia for testing)
NETWORK=arbitrum-sepolia

# Server
PORT=4021

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4021
